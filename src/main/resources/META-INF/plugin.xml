<idea-plugin>
    <id>me.SilverTime.lucky-clover</id>
    <name>Lucky Clover</name>
    <vendor email="bvzgong@gmail.com" url="https://github.com/SilverTime">SilverTime</vendor>
    <version>1.0.0</version>
    <idea-version since-build="242" until-build="251.*"/>

    <description><![CDATA[
    Lucky Clover!
    IntelliJ IDEA platform plugin. Supports instant stock market from USA, HK and China mainland.<br>
    IntelliJ IDEA 平台插件, 支持<b>股票</b>, <b>基金</b>和<b>数字货币</b>的行情数据的实时更新, 其中股票包括<b>美股</b>, <b>港股</b>和<b>A股</b>!.<br>
    插件名为幸运草，希望大家都有好运!<br>
    Good luck!<br>
    The most important thing is: Try <b>lucky-clover</b> and spread the word!<br>
    使用说明: https://github.com/SilverTime/lucky-clover
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService
                serviceImplementation="me.bytebeats.mns.ui.AppSettingState"/>

        <toolWindow
                id="Lucky Clover"
                displayName="Lucky Clover"
                icon="/icon_lucky_clover.png"
                anchor="left"
                factoryClass="me.bytebeats.mns.ui.MainWindow"/>

        <applicationConfigurable
                id="lucky-clover-setting"
                instance="me.bytebeats.mns.ui.SettingWindow"
                displayName="Lucky Clover"/>

        <notificationGroup
                displayType="NONE"
                id="Lucky Log"
                isLogByDefault="true"/>

        <notificationGroup
                displayType="BALLOON"
                id="Lucky Balloon"
                isLogByDefault="true"/>

        <notificationGroup
                displayType="TOOL_WINDOW"
                id="Lucky Tool Window"
                toolWindowId="Lucky Clover"
                isLogByDefault="true"/>

    </extensions>

    <actions>
        <!-- Add your actions here -->
    </actions>
</idea-plugin>